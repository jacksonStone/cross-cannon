{"author":"The Church History of Eusebius","book":"Supplementary Notes and Tables.","chapter":25,"classification":{"bucket":"Patristic / broadly orthodox","canonicalStatus":"patristic","contentKind":"primary","cautionReason":"No major mainstream heresy warning is attached by the preview classifier.","doctrinalStatus":"orthodox","labels":["patristic"],"severity":0},"id":"npnf201:iii.xvii.xxvi","lineage":["The Church History of Eusebius.","Supplementary Notes and Tables.","Bishops of Antioch."],"metadata":{"author":"The Church History of Eusebius","authorshipDateRange":null,"ccel":{"id":"npnf201","sourceUrl":"https://www.ccel.org/ccel/schaff/npnf201.xml","title":"NPNF2-01. Eusebius Pamphilius: Church History, Life of Constantine, Oration in Praise of Constantine"},"source":{"id":"npnf201","provider":"CCEL","sourceUrl":"https://www.ccel.org/ccel/schaff/npnf201.xml","title":"NPNF2-01. Eusebius Pamphilius: Church History, Life of Constantine, Oration in Praise of Constantine"}},"originalBook":null,"sourceVolumeId":"npnf201","title":"Bishops of Antioch.","source":{"id":"npnf201","sourceUrl":"https://www.ccel.org/ccel/schaff/npnf201.xml","title":"NPNF2-01. Eusebius Pamphilius: Church History, Life of Constantine, Oration in Praise of Constantine"},"verses":[{"book":"Supplementary Notes and Tables.","chapter":25,"text":"(Dates taken from the table given by Harnack in his Zeit des Ignatius, p.","verse":1},{"book":"Supplementary Notes and Tables.","chapter":25,"text":"Zebinus, died between 238 and 249.","verse":2},{"book":"Supplementary Notes and Tables.","chapter":25,"text":"Babylas, died in 250, during the persecution of Decius.","verse":3},{"book":"Supplementary Notes and Tables.","chapter":25,"text":"Fabius, died toward the end of 252 or early in 253.","verse":4},{"book":"Supplementary Notes and Tables.","chapter":25,"text":"Demetrian, died between 257 and 260.","verse":5},{"book":"Supplementary Notes and Tables.","chapter":25,"text":"Paul, deposed between 266 and 269 (probably in 268).","verse":6},{"book":"Supplementary Notes and Tables.","chapter":25,"text":"Theophilus, died not earlier than 182.","verse":7},{"book":"Supplementary Notes and Tables.","chapter":25,"text":"Maximinus, died between 189 and 192.","verse":8},{"book":"Supplementary Notes and Tables.","chapter":25,"text":"Timæus, died about 280.","verse":9},{"book":"Supplementary Notes and Tables.","chapter":25,"text":"Serapion, died about 209.","verse":10},{"book":"Supplementary Notes and Tables.","chapter":25,"text":"Cyril, sent to the mines in 303, and died probably toward the end of 306.","verse":11},{"book":"Supplementary Notes and Tables.","chapter":25,"text":"Asclepiades, died between 211 and 222.","verse":12},{"book":"Supplementary Notes and Tables.","chapter":25,"text":"Tyrannus, succeeded Cyril probably in 303, possibly not until 306, and lived until the close of the persecution.","verse":13},{"book":"Supplementary Notes and Tables.","chapter":25,"text":"Philetus, died not long before 229–231.","verse":14}]}