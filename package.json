{
  "name": "cross-cannon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "remix vite:build",
    "update-db:scripture-cache": "CROSS_CANNON_UPDATE_DB=1 node --import tsx scripts/build-scripture-cache.ts",
    "dev": "remix vite:dev --host 127.0.0.1 --port 3005",
    "start": "NODE_ENV=production remix-serve ./build/server/index.js",
    "typecheck": "tsc --noEmit",
    "render:architecture": "node scripts/render-architecture.mjs",
    "parse:church-fathers": "python3 scripts/parse-church-fathers.py",
    "build:church-fathers-preview": "python3 scripts/build-church-fathers-preview-assets.py",
    "index:church-fathers": "node --import tsx scripts/index-church-fathers.ts",
    "query:church-fathers": "node --import tsx scripts/query-church-fathers.ts",
    "verify": "scripts/verify.sh",
    "verify-prod": "scripts/verify-prod.sh",
    "ship": "CROSS_CANNON_UPDATE_DB=0 npm run verify && CROSS_CANNON_UPDATE_DB=0 ./deploy.sh && sleep 4 && npm run verify-prod",
    "index:bible": "node --import tsx scripts/index-bible.ts",
    "index:genesis": "node --import tsx scripts/index-bible.ts data/bible.json --reset --passage-type paragraph --book Genesis",
    "smoke:index": "EMBEDDING_PROVIDER=mock node --import tsx scripts/index-bible.ts data/sample-bible.json --reset --limit 10 --passage-type paragraph"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "@remix-run/node": "2.16.0",
    "@remix-run/react": "2.16.0",
    "@remix-run/serve": "2.16.0",
    "isbot": "^5.1.31",
    "openai": "^6.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "@remix-run/dev": "2.16.0",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.11"
  },
  "engines": {
    "node": ">=20.15.0"
  }
}
